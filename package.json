{
  "name": "skilldock",
  "version": "1.0.7",
  "description": "Local graphical console for npx skills and npx add-mcp.",
  "author": "SkillDock Contributors",
  "private": false,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "bin": {
    "skilldock": "bin/skilldock.js"
  },
  "files": [
    "bin",
    "apps/server/dist",
    "apps/web/dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:desktop": "node ./scripts/dev-desktop.mjs",
    "start": "node ./bin/skilldock.js",
    "build": "pnpm -r build",
    "build:desktop": "pnpm --filter @skilldock/desktop build",
    "build:desktop:assets": "python ./scripts/generate-desktop-icons.py",
    "dist:desktop:win": "pnpm build:desktop:assets && pnpm build && electron-builder --config apps/desktop/electron-builder.yml --win nsis",
    "dist:desktop:mac": "pnpm build:desktop:assets && pnpm build && electron-builder --config apps/desktop/electron-builder.yml --mac dmg",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "prepack": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "typescript": "latest"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "execa": "^9.6.1",
    "fastify": "^5.8.5",
    "zod": "^4.4.3"
  }
}
